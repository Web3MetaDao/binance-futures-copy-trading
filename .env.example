# ════════════════════════════════════════════════════════
#  币安跟单系统 Pro — 配置模板
#  复制为 .env 并填入真实值后运行
# ════════════════════════════════════════════════════════

# ── Binance API ──────────────────────────────────────────
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here
BINANCE_TESTNET=false          # true=测试网, false=正式网

# ── 多交易员配置（JSON 数组）────────────────────────────
# name: 交易员名称, url: 分享链接, weight: 权重(越高跟单比例越大)
# 支持三种格式：
#   1. uni-qr 分享链接（系统自动解析 encryptedUid）
#   2. leaderboard URL（含 encryptedUid= 参数）
#   3. 直接填写 encryptedUid（32位十六进制）
LEADERS_JSON=[
  {"name":"lanaai","url":"https://app.binance.com/uni-qr/cpro/lanaai?l=zh-CN&r=G2QKVGHN&uc=app_square_share_link&us=copylink","weight":1.0}
]
# 多交易员示例（取消注释并添加更多）：
# LEADERS_JSON=[
#   {"name":"lanaai","url":"https://app.binance.com/uni-qr/cpro/lanaai?l=zh-CN&r=G2QKVGHN&uc=app_square_share_link&us=copylink","weight":1.0},
#   {"name":"trader2","url":"https://app.binance.com/uni-qr/cpro/xxxxx?l=zh-CN&r=XXXXXXXX","weight":0.5},
#   {"name":"trader3","url":"https://www.binance.com/en/futures-activity/leaderboard?encryptedUid=ABCD1234ABCD1234ABCD1234ABCD1234","weight":0.8}
# ]

# ── 轮询间隔 ─────────────────────────────────────────────
POLL_INTERVAL=30               # 秒

# ── 资金模式 ─────────────────────────────────────────────
CAPITAL_RATIO=0.1              # 每笔用余额的 10%
RISK_MULTIPLIER=1.0            # 风险倍数
MAX_NOTIONAL_PER_SYMBOL=500    # 单币最大名义仓位 USDT
MAX_TOTAL_NOTIONAL=2000        # 总最大名义仓位 USDT

# 固定跟单员模式（开启后忽略 CAPITAL_RATIO）
FIXED_FOLLOWER_ENABLED=false
FIXED_FOLLOWER_NOTIONAL_USDT=50

# ── 复利（真复利模式）───────────────────────────────────────────────────
# 每笔平仓后立即从交易所拉取最新余额作为下一笔开仓的基础资金（真复利）
# 盈利 → 自动扩大仓位；亏损 → 自动缩小仓位
COMPOUND_ENABLED=true
COMPOUND_REINVEST_RATIO=1.0    # 真复利模式固定为 1.0，无需修改
# ── 绩效目标 ─────────────────────────────────────────────
TARGET_PL_RATIO_MIN=1.5
TARGET_PL_RATIO_MAX=3.0
TARGET_SHARPE_MIN=1.5
TARGET_SHARPE_MAX=3.0
PERFORMANCE_WINDOW=20          # 滚动窗口笔数

# ── 风控 ─────────────────────────────────────────────────
STOP_LOSS_PCT=0.05             # 5% 止损
TAKE_PROFIT_PCT=0.10           # 10% 止盈
MAX_DRAWDOWN_PCT=0.15          # 15% 最大回撤触发熔断
CIRCUIT_BREAKER_MINUTES=60     # 熔断暂停分钟数
EMPTY_SNAPSHOT_TOLERANCE=3     # 连续空快照容忍次数
NO_REVERSE=true                # 禁止反手
# SYMBOL_WHITELIST=BTCUSDT,ETHUSDT   # 白名单（留空=全部）
# SYMBOL_BLACKLIST=SHIBUSDT          # 黑名单

# ── API 重试 ─────────────────────────────────────────────
API_RETRY_TIMES=3
API_RETRY_BACKOFF=2.0          # 指数退避基数（# ── Smart Money 评分器 ───────────────────────────────────────────
SMART_MONEY_ENABLED=true
SMART_MONEY_MIN_SCORE=0.4      # 低于此分数跳过信号
OI_PERIOD=5m
ATR_PERIOD=14
HIGH_VOL_SKIP=true
HIGH_VOL_ATR_MULT=2.5          # ATR > 均値 2.5 倍时跳过

# ── Smart Money 备用信号链路 ─────────────────────────────────
# 当主链路（公开实盘抓取）失败或无信号时，自动切换到 Binance 排行榜聪明钱链路
SM_SOURCE_ENABLED=true

# 信号模式:
#   fallback — 主链路失败后切换到备用（默认，保守）
#   merge    — 主备信号融合，备用信号降权后补充主链路（激进）
SM_SIGNAL_MERGE_MODE=fallback

# 主链路连续无信号/失败多少次后切换备用链路
SM_FALLBACK_THRESHOLD=3

# 融合模式下备用信号降权系数（0.6 = 备用信号权重为主链路的 60%）
SM_MERGE_WEIGHT_FACTOR=0.6

# 从排行榜抓取头部 N 名公开持仓交易员
SM_SOURCE_TOP_N=10

# 排行榜排序方式: ROI（收益率）| PNL（盈丏额）| COPIERS（跟单人数）
SM_SOURCE_SORT_TYPE=ROI

# 合约类型: PERPETUAL（USDT-M）| DELIVERY（COIN-M）
SM_SOURCE_TRADE_TYPE=PERPETUAL

# ── Telegram 通知 ─────────────────────────────────────────
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ── 回测参数 ─────────────────────────────────────────────
BACKTEST_FEE_BPS=4.0           # 手续费 bps（0.04%）
BACKTEST_SLIPPAGE_BPS=2.0      # 滑点 bps（0.02%）

# ── Web 面板 ─────────────────────────────────────────────
WEB_HOST=0.0.0.0
WEB_PORT=5000
WEB_SECRET=changeme            # 修改配置时需要的密钥

# ── 日志 ─────────────────────────────────────────────────
LOG_DIR=logs
STATE_FILE=data/state.json
